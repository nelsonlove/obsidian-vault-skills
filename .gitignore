**/.DS_Store

# Generated Claude Code plugin content — a projection of your vault, regenerated
# locally by the exporter. Only the scaffold (plugin.json, README, the static new-skill authoring skill) is tracked.
claude-code/skills/*
!claude-code/skills/.gitkeep
!claude-code/skills/new-skill
!claude-code/skills/new-skill/**
claude-code/agents/*
!claude-code/agents/.gitkeep
claude-code/.vault-skills-manifest.json

# Internal delivery registry (ops skill) — local-only, not part of the product
.ops/

# Dependencies — never tracked (a committed symlink here broke fresh checkouts once)
node_modules/
